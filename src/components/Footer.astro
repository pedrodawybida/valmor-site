<footer class="footer">
  <div class="container footer-inner">

    <div class="footer-brand">
      <img src="/assets/logo-new.png" alt="Valmor Alves Advocacia" class="footer-logo" loading="lazy" />
      <p class="footer-tagline">Especialistas em benefícios do INSS.<br/>Atendimento online · Todo o Brasil.</p>
    </div>

    <div class="footer-cols">
      <div class="footer-col">
        <span class="footer-col-title">Benefícios</span>
        <ul>
          <li><a href="#servicos">BPC / LOAS</a></li>
          <li><a href="#servicos">Auxílio-Doença</a></li>
          <li><a href="#servicos">Auxílio-Acidente</a></li>
          <li><a href="#servicos">Salário-Maternidade</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <span class="footer-col-title">Contato</span>
        <ul>
          <li>
            <a href="https://wa.me/554198959929" target="_blank">
              WhatsApp: (41) 9895-9929
            </a>
          </li>
          <li>Curitiba, PR</li>
        </ul>
      </div>
    </div>

  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <span>&copy; {new Date().getFullYear()} Valmor Alves Advocacia. Todos os direitos reservados.</span>
      <span class="footer-oab">OAB/PR · Direito Previdenciário</span>
    </div>
  </div>
</footer>

<style is:global>
  .footer {
    background: var(--navy);
    padding-top: var(--s12);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s8);
    padding-bottom: var(--s8);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .footer-logo { max-width: 180px; margin-bottom: var(--s3); }

  .footer-tagline {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.35);
    line-height: 1.65;
    font-family: var(--sans);
  }

  .footer-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s6);
  }

  .footer-col-title {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.30);
    font-family: var(--sans);
    margin-bottom: 18px;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-col ul li,
  .footer-col ul li a {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.52);
    font-family: var(--sans);
    transition: color 0.2s;
  }

  .footer-col ul li a:hover { color: rgba(255,255,255,0.85); }

  /* Bottom bar */
  .footer-bottom {
    padding: var(--s4) 0;
  }

  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s4);
    flex-wrap: wrap;
  }

  .footer-bottom-inner span {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.22);
    font-family: var(--sans);
  }

  .footer-oab {
    color: rgba(255,255,255,0.22) !important;
  }

  @media (max-width: 767px) {
    .footer-inner { grid-template-columns: 1fr; gap: var(--s6); }
    .footer-bottom-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
