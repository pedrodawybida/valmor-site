          </svg>
          Falar no WhatsApp agora
        </a>

        <p class="cta-disclaimer">
          ★★★★★ · 88 avaliações Google · Resposta em minutos
        </p>

      </div>
    </div>

  </div>
</section>

<style is:global>
  .cta-section {
    background: var(--navy);
    padding: var(--s16) 0;
    position: relative;
    overflow: hidden;
  }

  /* Background blobs */
  .cta-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .cta-bg-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.08;
  }

  .cta-blob-1 {
    width: 500px; height: 500px;
    background: var(--gold);
    top: -200px; right: -100px;
  }

  .cta-blob-2 {
    width: 300px; height: 300px;
    background: var(--gold-light);
    bottom: -150px; left: 10%;
  }

  /* Inner */
  .cta-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: var(--s12);
    align-items: center;
  }

  /* Left */
  .cta-left .section-title-light {
    font-size: clamp(2rem, 3.8vw, 3.2rem);
    margin-bottom: var(--s4);
    line-height: 1.12;
  }

  .cta-body {
    font-size: 0.97rem;
    color: rgba(255,255,255,0.46);
    line-height: 1.72;
    max-width: 480px;
    margin-bottom: var(--s6);
  }

  /* Checks */
  .cta-checks {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .cta-check {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.65);
    font-family: var(--sans);
    line-height: 1.5;
  }

  .cta-check svg { flex-shrink: 0; margin-top: 1px; }

  .cta-check strong { color: rgba(255,255,255,0.88); font-weight: 600; }

  /* Card */
  .cta-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: var(--r-xl);
    padding: 36px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    backdrop-filter: blur(12px);
  }

  /* Card header */
  .cta-card-header {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .cta-avatar {
    width: 52px; height: 52px;
    border-radius: 50%;
    background: rgba(201,168,76,0.10);
    border: 1px solid rgba(201,168,76,0.20);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .cta-card-name {
    font-size: 0.92rem;
    font-weight: 700;
    color: rgba(255,255,255,0.90);
    font-family: var(--sans);
    line-height: 1.2;
  }

  .cta-card-oab {
    font-size: 0.74rem;
    color: rgba(255,255,255,0.38);
    font-family: var(--sans);
    margin-top: 2px;
  }

  /* Online badge */
  .cta-online-badge {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.72rem;
    font-weight: 600;
    color: #4ade80;
    font-family: var(--sans);
    background: rgba(74,222,128,0.10);
    border: 1px solid rgba(74,222,128,0.18);
    padding: 5px 10px;
    border-radius: 100px;
    flex-shrink: 0;
  }

  .cta-online-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #4ade80;
    animation: blink 1.8s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .cta-card-divider {
    height: 1px;
    background: rgba(255,255,255,0.06);
  }

  .cta-card-message {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.52);
    line-height: 1.7;
    font-family: var(--sans);
    font-style: italic;
  }

  .cta-btn {
    width: 100%;
    font-size: 1rem;
    font-weight: 700;
    padding: 17px;
    border-radius: var(--r-md);
    gap: 10px;
    justify-content: center;
    box-shadow: 0 8px 32px rgba(201,168,76,0.38);
  }

  .cta-disclaimer {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.25);
    font-family: var(--sans);
    text-align: center;
    letter-spacing: 0.2px;
  }

  @media (max-width: 960px) {
    .cta-inner { grid-template-columns: 1fr; gap: var(--s8); }
    .cta-right { max-width: 480px; }
  }

  @media (max-width: 767px) {
    .cta-section { padding: var(--s12) 0; }
    .cta-card { padding: 24px 20px; }
    .cta-right { max-width: 100%; }
  }
</style>
