---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import StatsBar from '../components/StatsBar.astro';
import BentoGrid from '../components/BentoGrid.astro';
import Objections from '../components/Objections.astro';
import HowItWorks from '../components/HowItWorks.astro';
import About from '../components/About.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import CtaFinal from '../components/CtaFinal.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Advogado Previdenciário | BPC/LOAS, Auxílio-Doença, Acidente e Maternidade | Valmor Alves"
  description="INSS negou seu benefício? Especialistas em BPC/LOAS, Auxílio-Doença, Auxílio-Acidente e Salário-Maternidade. Análise gratuita, honorários só no êxito. Atendimento online para todo o Brasil. OAB/PR."
>
  <Navbar />
  <main>
    <!-- 1. Captura de atenção + identificação do problema -->
    <Hero />
    <!-- 2. Prova social imediata + números -->
    <StatsBar />
    <!-- 3. Identificação: qual é o seu benefício? -->
    <BentoGrid />
    <!-- 4. Quebra de objeções principais -->
    <Objections />
    <!-- 5. Como funciona — reduz fricção do processo -->
    <HowItWorks />
    <!-- 6. Autoridade e confiança no advogado -->
    <About />
    <!-- 7. Prova social: depoimentos reais -->
    <Testimonials />
    <!-- 8. FAQ: elimina dúvidas restantes -->
    <FAQ />
    <!-- 9. CTA final com urgência -->
    <CtaFinal />
  </main>
  <Footer />
</Layout>
