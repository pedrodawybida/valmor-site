---

<!-- Barra de urgência no topo -->
<div class="topbar" id="topbar" role="banner" aria-label="Oferta especial">
  <div class="topbar-inner">
    <span class="topbar-dot" aria-hidden="true"></span>
    <p class="topbar-text">
      <strong>Análise gratuita disponível agora</strong> — Descubra em 24h se você tem direito a receber
    </p>
    <a
      href="https://wa.me/554198959929?text=Ol%C3%A1!%20Vi%20o%20site%20e%20quero%20minha%20an%C3%A1lise%20gratuita."
      target="_blank"
      class="topbar-cta"
      aria-label="Iniciar análise gratuita no WhatsApp"
    >
      Começar →
    </a>
    <button class="topbar-close" id="topbarClose" aria-label="Fechar barra">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>
</div>

<nav class="navbar" id="navbar" role="navigation" aria-label="Navegação principal">
  <div class="container nav-inner">
    <a href="/" class="nav-brand" aria-label="Valmor Alves Advocacia - Início">
      <img src="/assets/logo-new.png" alt="Valmor Alves Advocacia" class="nav-logo" />
    </a>

    <div class="nav-links" id="navLinks" role="list">
      <a href="#beneficios" class="nav-link" role="listitem">Benefícios</a>
      <a href="#sobre" class="nav-link" role="listitem">Sobre</a>
      <a href="#avaliacoes" class="nav-link" role="listitem">Depoimentos</a>
      <a href="#duvidas" class="nav-link" role="listitem">FAQ</a>
      <a
        href="https://wa.me/554198959929?text=Ol%C3%A1!%20Gostaria%20de%20uma%20an%C3%A1lise%20gratuita%20do%20meu%20caso%20no%20INSS."
        target="_blank"
        class="nav-cta"
        id="nav-cta-btn"
        role="listitem"
        aria-label="Análise gratuita no WhatsApp"
      >
        Análise Gratuita
      </a>
    </div>

    <button class="nav-toggle" id="navToggle" aria-label="Abrir menu de navegação" aria-expanded="false" aria-controls="navLinks">
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>
  </div>
</nav>

<script is:inline>
  // Topbar close
  var topbar = document.getElementById('topbar');
  var topbarClose = document.getElementById('topbarClose');
  var TOPBAR_DISMISSED = 'tb_dismissed';

  if (sessionStorage.getItem(TOPBAR_DISMISSED)) {
    if (topbar) topbar.style.display = 'none';
  }

  if (topbarClose) {
    topbarClose.addEventListener('click', function () {
      topbar.style.display = 'none';
      sessionStorage.setItem(TOPBAR_DISMISSED, '1');
    });
  }

  // Navbar scroll
  function updateNavbar() {
    var nav = document.getElementById('navbar');
    if (nav) {
      nav.classList.toggle('scrolled', window.scrollY > 40);
    }
  }
  
  window.addEventListener('scroll', updateNavbar);
  window.addEventListener('load', updateNavbar);
  // Also run immediately in case it's a client-side navigation or fast render
  updateNavbar();

  // Mobile menu
  var toggle = document.getElementById('navToggle');
  var links = document.getElementById('navLinks');
  toggle.addEventListener('click', function () {
    var isOpen = links.classList.toggle('open');
    this.classList.toggle('active');
    this.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  // Close mobile menu on link click
  document.querySelectorAll('.nav-link').forEach(function(link) {
    link.addEventListener('click', function() {
      links.classList.remove('open');
      toggle.classList.remove('active');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });
  });
</script>

<style is:global>
  /* ── Topbar ── */
  .topbar {
    background: var(--gold);
    padding: 10px 20px;
    position: relative;
    z-index: 101;
  }

  .topbar-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .topbar-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--navy);
    opacity: 0.5;
    flex-shrink: 0;
    animation: blink 2s ease-in-out infinite;
  }

  @keyframes blink {
    0%,100% { opacity: 0.5; }
    50%      { opacity: 1; }
  }

  .topbar-text {
    font-size: 0.82rem;
    color: var(--navy);
    font-family: var(--sans);
    line-height: 1.3;
    text-align: center;
  }

  .topbar-text strong { font-weight: 700; }

  .topbar-cta {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--navy);
    font-family: var(--sans);
    padding: 4px 12px;
    background: rgba(10,22,40,0.12);
    border-radius: 100px;
    transition: background 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .topbar-cta:hover { background: rgba(10,22,40,0.22); }

  .topbar-close {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    color: var(--navy);
    opacity: 0.5;
    padding: 4px;
    transition: opacity 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .topbar-close:hover { opacity: 0.9; }

  /* ── Navbar ── */
  .navbar {
    position: sticky;
    top: 0;
    left: 0; width: 100%;
    z-index: 100;
    padding: 20px 0;
    background: var(--navy);
    transition: all 0.3s ease;
  }

  .navbar.scrolled {
    background: rgba(10,22,40,0.96);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    padding: 13px 0;
    box-shadow: 0 1px 0 rgba(255,255,255,0.05);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo { height: 64px; width: auto; }

  .nav-links {
    display: none;
    align-items: center;
    gap: 32px;
  }

  @media (min-width: 768px) {
    .nav-links { display: flex; }
  }

  .nav-link {
    font-size: 0.86rem;
    font-weight: 500;
    color: rgba(255,255,255,0.60);
    transition: color 0.2s;
    letter-spacing: 0.1px;
  }
  .nav-link:hover { color: rgba(255,255,255,0.95); }

  .nav-cta {
    font-size: 0.84rem;
    font-weight: 600;
    color: var(--navy);
    background: var(--gold);
    padding: 9px 22px;
    border-radius: var(--r-sm);
    transition: all 0.2s ease;
    letter-spacing: 0.1px;
    white-space: nowrap;
  }
  .nav-cta:hover {
    background: var(--gold-light);
    transform: translateY(-1px);
  }

  /* ── Hamburger ── */
  .nav-toggle {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    z-index: 200;
  }
  @media (min-width: 768px) { .nav-toggle { display: none; } }

  .nav-toggle span {
    width: 22px;
    height: 2px;
    background: rgba(255,255,255,0.8);
    border-radius: 2px;
    transition: all 0.3s ease;
    display: block;
  }

  .nav-toggle.active span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  .nav-toggle.active span:nth-child(2) { opacity: 0; }
  .nav-toggle.active span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

  /* ── Mobile menu ── */
  .nav-links.open {
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100vh;
    background: var(--navy);
    padding: 100px 32px 40px;
    gap: 24px;
    align-items: center;
    justify-content: flex-start;
    z-index: 99;
  }

  .nav-links.open .nav-link {
    font-size: 1.5rem;
    color: rgba(255,255,255,0.78);
    font-weight: 400;
    font-family: var(--serif);
  }

  .nav-links.open .nav-cta {
    font-size: 1rem;
    padding: 14px 36px;
    margin-top: 12px;
    border-radius: var(--r-md);
  }

  /* Mobile topbar adjustments */
  @media (max-width: 767px) {
    .topbar { padding: 8px 40px 8px 16px; }
    .topbar-inner { gap: 8px; flex-wrap: nowrap; justify-content: flex-start; }
    .topbar-text { font-size: 0.76rem; text-align: left; }
    .topbar-dot { display: none; }
  }
</style>
