---
const objections = [
  {
    id: "obj-waiting",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: "\"Vou esperar para ver como fica...\"",
    truth: "O que você perde esperando",
    body: "Benefícios previdenciários retroagem à data do pedido — não da sentença. Cada mês que você adia é um mês de benefício que pode não receber. Muitos benefícios têm prazo para entrar com recurso.",
    urgency: "Não tem custo esperar? Tem — custa um salário mínimo por mês.",
  },
  {
    id: "obj-cost",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
    title: "\"Advogado é caro, não tenho dinheiro...\"",
    truth: "A realidade dos nossos honorários",
    body: "Trabalhamos exclusivamente no modelo de êxito — você não paga nada antes de ganhar. Os honorários são descontados apenas da retroatividade recebida. Se não ganhar, não paga nada. R$ 0 de custo inicial.",
    urgency: "Sem dinheiro agora? Perfeito. Você só paga se e quando ganhar.",
  },
  {
    id: "obj-rights",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
    title: "\"Nem sei se tenho direito...\"",
    truth: "Por isso existe a análise gratuita",
    body: "Você não precisa saber se tem direito — é exatamente isso que descobrimos na análise gratuita. Em 24 horas, te dizemos se há direito ao benefício, qual é, e qual a melhor estratégia. Sem compromisso, sem custo.",
    urgency: "Manda uma mensagem agora. A análise não te custa nada — a demora pode custar muito.",
  },
];
---

<section class="objections-section" aria-labelledby="objections-heading">
  <div class="container">

    <div class="obj-header">
      <span class="section-eyebrow">Quebrando objeções</span>
      <h2 class="section-title" id="objections-heading">
        O que passa pela sua cabeça<br/>antes de entrar em contato
      </h2>
      <p class="section-body">
        Essas são as dúvidas mais comuns. Veja por que nenhuma delas
        deveria te impedir de buscar o que é seu por direito.
      </p>
    </div>

    <div class="obj-grid" role="list">
      {objections.map((obj) => (
        <div class="obj-card" role="listitem" id={obj.id}>
          <div class="obj-icon" aria-hidden="true" set:html={obj.icon} />
          <blockquote class="obj-quote">{obj.title}</blockquote>
          <div class="obj-divider" aria-hidden="true">
            <span class="obj-divider-label">{obj.truth}</span>
          </div>
          <p class="obj-body">{obj.body}</p>
          <p class="obj-urgency">{obj.urgency}</p>
        </div>
      ))}
    </div>

    <div class="obj-cta">
      <a
        href="https://wa.me/554198959929?text=Ol%C3%A1!%20Quero%20saber%20se%20tenho%20direito%20a%20algum%20benef%C3%ADcio%20do%20INSS."
        target="_blank"
        class="btn btn-gold obj-btn"
        id="objections-cta"
        aria-label="Iniciar análise gratuita no WhatsApp"
      >
        Descobrir meus direitos gratuitamente
      </a>
      <p class="obj-cta-note">Análise gratuita · Sem compromisso · R$0 adiantado</p>
    </div>

  </div>
</section>

<style is:global>
  .objections-section {
    background: var(--stone);
    padding: var(--s8) 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .obj-header {
    max-width: 580px;
    margin-bottom: var(--s6);
  }

  .obj-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: var(--s6);
  }

  .obj-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .obj-card:hover {
    box-shadow: 0 8px 32px rgba(10,22,40,0.08);
    transform: translateY(-2px);
  }

  .obj-icon {
    width: 48px; height: 48px;
    border-radius: var(--r-md);
    background: var(--gold-dim);
    color: var(--gold);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .obj-quote {
    font-family: var(--serif);
    font-size: 1.18rem;
    color: var(--navy);
    line-height: 1.35;
    font-style: normal;
    border: none;
    margin: 0;
    padding: 0;
  }

  .obj-divider {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 4px 0;
  }

  .obj-divider::before,
  .obj-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .obj-divider-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--gold);
    font-family: var(--sans);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .obj-body {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.72;
  }

  .obj-urgency {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--navy);
    font-family: var(--sans);
    padding: 12px 16px;
    background: var(--gold-dim);
    border-radius: var(--r-sm);
    line-height: 1.4;
    border-left: 2px solid var(--gold);
    margin-top: auto;
  }

  /* CTA */
  .obj-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    text-align: center;
  }

  .obj-btn {
    font-size: 0.95rem;
    font-weight: 700;
    padding: 14px 32px;
    border-radius: var(--r-md);
    box-shadow: 0 6px 28px rgba(201,168,76,0.30);
  }

  .obj-cta-note {
    font-size: 0.74rem;
    color: var(--text-secondary);
    font-family: var(--sans);
  }

  @media (max-width: 900px) {
    .obj-grid { grid-template-columns: 1fr; }
    .obj-card { flex-direction: column; }
  }

  @media (max-width: 767px) {
    .objections-section { padding: var(--s12) 0; }
    .obj-header { margin-bottom: var(--s8); }
    .obj-grid { gap: 16px; margin-bottom: var(--s8); }
    .obj-card { padding: 24px 20px; }
    .obj-btn { width: 100%; }
  }
</style>
