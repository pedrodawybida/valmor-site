---
<section class="hero">
  <div class="hero-bg">
    <img src="/assets/generated_hero_bg.png" alt="" class="hero-img" loading="eager" aria-hidden="true" />
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-body">

    <!-- Pill de social proof -->
    <div class="hero-pill" role="img" aria-label="88 avaliações 5 estrelas no Google">
      <span class="pill-stars" aria-hidden="true">★★★★★</span>
      <span class="pill-text">88 avaliações · Google · OAB/PR</span>
    </div>

    <h1 class="hero-title">
      O INSS negou ou demorou?<br/>
      <em>A gente cobra o que é seu.</em>
    </h1>

    <p class="hero-sub">
      Especialistas em garantir os benefícios que o INSS nega ou atrasa —
      análise gratuita, sem burocracia e <strong>você só paga se ganhar.</strong>
    </p>

    <!-- 4 benefícios visíveis no fold -->
    <div class="hero-benefits" role="list" aria-label="Benefícios que atuamos">
      <a
        href="https://wa.me/554198959929?text=Ol%C3%A1!%20Preciso%20de%20ajuda%20com%20o%20BPC%2FLOAS."
        target="_blank"
        class="hb-chip"
        role="listitem"
        aria-label="Falar sobre BPC/LOAS"
      >
        <span class="hb-icon">🧓</span>
        <span>BPC / LOAS</span>
      </a>
      <a
        href="https://wa.me/554198959929?text=Ol%C3%A1!%20Preciso%20de%20ajuda%20com%20o%20Aux%C3%ADlio-Doen%C3%A7a."
        target="_blank"
        class="hb-chip"
        role="listitem"
        aria-label="Falar sobre Auxílio-Doença"
      >
        <span class="hb-icon">🏥</span>
        <span>Auxílio-Doença</span>
      </a>
      <a
        href="https://wa.me/554198959929?text=Ol%C3%A1!%20Preciso%20de%20ajuda%20com%20o%20Aux%C3%ADlio-Acidente."
        target="_blank"
        class="hb-chip"
        role="listitem"
        aria-label="Falar sobre Auxílio-Acidente"
      >
        <span class="hb-icon">⚠️</span>
        <span>Auxílio-Acidente</span>
      </a>
      <a
        href="https://wa.me/554198959929?text=Ol%C3%A1!%20Preciso%20de%20ajuda%20com%20o%20Aux%C3%ADlio-Maternidade."
        target="_blank"
        class="hb-chip"
        role="listitem"
        aria-label="Falar sobre Auxílio-Maternidade"
      >
        <span class="hb-icon">🤱</span>
        <span>Aux. Maternidade</span>
      </a>
    </div>

    <!-- CTA principal -->
    <div class="hero-actions">
      <a
        href="https://wa.me/554198959929?text=Ol%C3%A1!%20Vi%20o%20site%20e%20quero%20uma%20an%C3%A1lise%20gratuita%20do%20meu%20caso%20no%20INSS."
        target="_blank"
        class="btn btn-gold hero-btn-main"
        id="hero-cta-primary"
        aria-label="Iniciar análise gratuita no WhatsApp"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="flex-shrink:0">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
        </svg>
        Quero minha análise gratuita agora
      </a>
      <a
        href="https://wa.me/554198959929?text=Ol%C3%A1!%20O%20INSS%20negou%20meu%20benef%C3%ADcio%20e%20quero%20recorrer."
        target="_blank"
        class="btn-text-link"
        id="hero-cta-denied"
      >
        Meu benefício foi negado — quero recorrer →
      </a>
    </div>

    <!-- Trust row -->
    <div class="hero-trust" role="list" aria-label="Garantias do escritório">
      <span role="listitem">✓ Análise gratuita e sem compromisso</span>
      <span class="sep" aria-hidden="true">·</span>
      <span role="listitem">✓ Honorários só no êxito</span>
      <span class="sep" aria-hidden="true">·</span>
      <span role="listitem">✓ Atendimento online · Todo o Brasil</span>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll" aria-hidden="true">
    <div class="mouse"><div class="wheel"></div></div>
    <span class="scroll-text">Role para ver mais</span>
  </div>
</section>

<style is:global>
  /* ── Layout ── */
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    padding-top: 100px;
    padding-bottom: 20px;
    overflow: hidden;
    isolation: isolate;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      108deg,
      rgba(8,18,36,0.98) 0%,
      rgba(8,18,36,0.92) 42%,
      rgba(8,18,36,0.30) 100%
    );
  }

  /* ── Content ── */
  .hero-body {
    position: relative;
    z-index: 1;
    padding-bottom: 0px;
    width: 100%;
    max-width: 800px;
    margin-left: 0;
  }

  /* Social proof pill */
  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 5px 14px;
    border: 1px solid rgba(201,168,76,0.28);
    background: rgba(201,168,76,0.06);
    border-radius: 100px;
    margin-bottom: 12px;
    animation: fadeUp 0.5s ease both;
  }

  .pill-stars {
    color: var(--gold);
    font-size: 0.82rem;
    letter-spacing: 2px;
  }

  .pill-text {
    font-size: 0.78rem;
    font-weight: 500;
    color: rgba(255,255,255,0.55);
    font-family: var(--sans);
    letter-spacing: 0.2px;
  }

  /* Title */
  .hero-title {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 4.2vw, 3.6rem);
    color: var(--white);
    line-height: 1.05;
    letter-spacing: -0.5px;
    margin-bottom: 12px;
    animation: fadeUp 0.6s 0.05s ease both;
  }

  .hero-title em {
    font-style: italic;
    color: var(--gold);
  }

  /* Subtitle */
  .hero-sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.5;
    margin-bottom: 20px;
    max-width: 650px;
    animation: fadeUp 0.6s 0.1s ease both;
  }

  .hero-sub strong {
    color: rgba(255,255,255,0.82);
    font-weight: 600;
  }

  /* ── Benefit chips ── */
  .hero-benefits {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 20px;
    animation: fadeUp 0.6s 0.14s ease both;
  }

  .hb-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 14px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 100px;
    font-size: 0.78rem;
    font-weight: 600;
    font-family: var(--sans);
    color: rgba(255,255,255,0.85);
    transition: all 0.2s ease;
    cursor: pointer;
    text-decoration: none;
  }

  .hb-chip:hover {
    background: rgba(201,168,76,0.14);
    border-color: rgba(201,168,76,0.4);
    color: var(--gold-light);
    transform: translateY(-1px);
  }

  .hb-icon { font-size: 0.95rem; }

  /* Actions */
  .hero-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px;
    margin-bottom: 16px;
    animation: fadeUp 0.6s 0.18s ease both;
  }

  .hero-btn-main {
    font-size: 0.95rem;
    padding: 14px 28px;
    font-weight: 700;
    border-radius: 10px;
    gap: 8px;
    box-shadow: 0 6px 32px rgba(201,168,76,0.38);
    letter-spacing: 0.1px;
  }

  .btn-text-link {
    font-size: 0.88rem;
    font-weight: 500;
    color: rgba(255,255,255,0.48);
    font-family: var(--sans);
    transition: color 0.2s;
    padding: 2px 0;
    border-bottom: 1px solid rgba(255,255,255,0.15);
  }

  .btn-text-link:hover {
    color: rgba(255,255,255,0.82);
    border-bottom-color: rgba(255,255,255,0.38);
  }

  /* Trust row */
  .hero-trust {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.72rem;
    color: rgba(255,255,255,0.38);
    font-family: var(--sans);
    flex-wrap: wrap;
    animation: fadeUp 0.6s 0.22s ease both;
  }

  .sep { opacity: 0.4; }

  /* Animations */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Scroll Indicator */
  .hero-scroll {
    position: absolute;
    bottom: -15px; /* Push it down slightly */
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    z-index: 10;
    opacity: 0.6;
    animation: fadeUp 0.6s 0.8s ease both;
  }

  .mouse {
    width: 20px;
    height: 32px;
    border: 2px solid rgba(255,255,255,0.5);
    border-radius: 12px;
    display: flex;
    justify-content: center;
    padding-top: 5px;
  }

  .wheel {
    width: 3px;
    height: 6px;
    background: rgba(255,255,255,0.7);
    border-radius: 2px;
    animation: scrollWheel 1.5s infinite;
  }

  .scroll-text {
    font-family: var(--sans);
    font-size: 0.65rem;
    color: rgba(255,255,255,0.6);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  @keyframes scrollWheel {
    0% { transform: translateY(0); opacity: 1; }
    100% { transform: translateY(8px); opacity: 0; }
  }

  /* ── Mobile ── */
  @media (max-width: 767px) {
    .hero {
      min-height: 80svh;
      padding-top: 30px;
      align-items: flex-end;
      padding-bottom: 50px;
    }

    .hero-overlay {
      background: linear-gradient(
        180deg,
        rgba(8,18,36,0.45) 0%,
        rgba(8,18,36,0.82) 40%,
        rgba(8,18,36,0.98) 65%
      );
    }

    .hero-body {
      max-width: 100%;
      padding-top: 20px;
      padding-bottom: 48px;
    }

    .hero-title { letter-spacing: -0.5px; font-size: clamp(2.2rem, 8vw, 3rem); }

    .hb-chip { font-size: 0.78rem; padding: 8px 13px; }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
      gap: 14px;
    }

    .hero-btn-main { width: 100%; justify-content: center; font-size: 1rem; padding: 18px; }
    .btn-text-link { text-align: center; }
  }
</style>
